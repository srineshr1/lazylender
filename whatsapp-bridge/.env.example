# WhatsApp Bridge Server Environment Variables
# Copy this file to .env for local development

# Get your key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional Groq model overrides
# Cheap fast text extraction model
GROQ_TEXT_MODEL=llama-3.1-8b-instant
# Vision-capable model for image + photo schedule parsing
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Bridge server port (default: 3001)
BRIDGE_PORT=3001

# Calendar app URL for CORS configuration (default: http://localhost:5173)
CALENDAR_URL=http://localhost:5173

# Additional allowed origins for CORS (comma-separated, e.g., http://localhost:5174,http://localhost:5175)
# Leave empty if not needed
ALLOWED_ORIGINS=

# Set to true in deployment/production to enforce bridge authentication
BRIDGE_REQUIRE_AUTH=true

# Admin API key for /admin endpoints (required to enable admin routes)
BRIDGE_ADMIN_API_KEY=replace_with_a_long_random_secret
