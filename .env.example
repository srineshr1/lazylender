# Frontend Environment Variables
# Copy this file to .env for local development

# ─── SECURITY NOTICE ────────────────────────────────────────────────────────
# NEVER set VITE_GROQ_API_KEY in production — VITE_* vars are baked into the
# JS bundle and visible to everyone who views source. Use the bridge proxy instead.
# ─────────────────────────────────────────────────────────────────────────────

# WhatsApp Bridge Configuration
# Local development: Leave VITE_BRIDGE_URL empty to use Vite's proxy
# Production: Set to your Railway/ngrok service URL
VITE_BRIDGE_URL=

# Route Groq API calls through the bridge server (hides API key from browser)
# MUST be true in production — the bridge holds GROQ_API_KEY securely server-side
VITE_USE_BRIDGE_PROXY=true

# Bridge server polling interval in milliseconds (default: 3000)
VITE_POLL_INTERVAL=3000

# Supabase Configuration
# Get these from your Supabase project settings (https://app.supabase.com)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Authentication Configuration
# Set to 'true' to require authentication even in development (default: false)
# In production, auth is always required
VITE_REQUIRE_AUTH=false
